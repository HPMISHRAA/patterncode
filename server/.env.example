# ─────────────────────────────────────────────
#  SERVER — Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# ── App ─────────────────────────────────────
PORT=5000
NODE_ENV=development   # Change to 'production' when deploying

# ── CORS ─────────────────────────────────────
# Your frontend URL (no trailing slash)
# Dev:        http://localhost:5173
# Production: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# ── Database (PostgreSQL) ────────────────────
# Local:      postgresql://postgres:password@localhost:5432/patterncode
# Neon.tech:  postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
# Docker:     postgresql://postgres:postgrespassword@db:5432/patterncode
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/patterncode

# ── Firebase Admin SDK ───────────────────────
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# IMPORTANT: The private key must have \n characters escaped as \\n
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBAD...\n-----END PRIVATE KEY-----\n"

# ── Judge0 Code Execution ────────────────────
# Option A: RapidAPI (easiest) — https://rapidapi.com/judge0-official/api/judge0-ce
#   JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
#   JUDGE0_API_KEY=your_rapidapi_key
#
# Option B: Self-hosted locally with Docker
#   JUDGE0_API_URL=http://localhost:2358
#   JUDGE0_API_KEY=   (leave empty for local)
JUDGE0_API_URL=http://localhost:2358
JUDGE0_API_KEY=
